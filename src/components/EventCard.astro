---
import { getImageUrl } from "../lib/image";

interface Props {
  title: string;
  date: Date;
  description?: string;
  slug: string;
  thumbnail?: string;
  location?: string;
}

const { title, date, description, slug, thumbnail, location } = Astro.props;

const formattedDate = date.toLocaleDateString("en-MY", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const thumbUrl = thumbnail
  ? getImageUrl(thumbnail, { width: 400, height: 260 })
  : `https://picsum.photos/seed/${slug}/400/260`;
---

<a
  href={`/events/${slug}`}
  class="group block bg-white rounded-2xl border border-cream-200 hover:border-cream-300 hover:shadow-xl transition-all duration-300 overflow-hidden"
>
  <!-- Image with gradient overlay -->
  <div class="relative aspect-[16/10] overflow-hidden bg-charcoal-800">
    <img
      src={thumbUrl}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal-800/60 via-transparent to-transparent"></div>
    <!-- Date badge -->
    <div class="absolute bottom-3 left-3">
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-black/40 backdrop-blur-sm text-white text-xs font-medium border border-white/10">
        <svg class="w-3 h-3 text-saffron-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
        </svg>
        <time datetime={date.toISOString().split("T")[0]}>{formattedDate}</time>
      </span>
    </div>
  </div>

  <div class="p-5 flex flex-col">
    <h3 class="font-semibold text-charcoal-800 group-hover:text-saffron-600 transition-colors leading-snug min-h-[2.75rem]">
      {title}
    </h3>

    {location && (
      <div class="flex items-start gap-1.5 mt-2 min-h-[1.5rem]">
        <svg class="w-3.5 h-3.5 shrink-0 mt-px text-saffron-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
        </svg>
        <span class="text-xs text-charcoal-400">{location}</span>
      </div>
    )}

    <p class="text-sm text-charcoal-500 mt-2 leading-relaxed line-clamp-2 min-h-[2.5rem]">
      {description ?? ""}
    </p>
  </div>
</a>
