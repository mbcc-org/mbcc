---
import { getImageUrl } from "../lib/image";

interface Props {
  name: string;
  abbreviation?: string;
  tradition?: "mahayana" | "theravada" | "vajrayana";
  description?: string;
  logo?: string;
  slug: string;
  role?: "founding-member" | "national-org";
}

const { name, abbreviation, tradition, description, logo, slug, role } = Astro.props;

const traditionColors = {
  mahayana: "bg-saffron-100 text-saffron-700 border-saffron-200",
  theravada: "bg-bodhi-100 text-bodhi-600 border-bodhi-200",
  vajrayana: "bg-crimson-100 text-crimson-600 border-crimson-200",
};

const traditionAccent = {
  mahayana: "border-saffron-300",
  theravada: "border-bodhi-400",
  vajrayana: "border-crimson-400",
};

const logoUrl = logo ? getImageUrl(logo, { width: 120, height: 120 }) : "";
---

<a
  href={`/organisations/${slug}`}
  class:list={[
    "group block bg-white rounded-xl border border-cream-200 hover:border-cream-300 hover:shadow-lg transition-all duration-200 overflow-hidden",
    tradition && `border-t-2 ${traditionAccent[tradition]}`,
  ]}
>
  <div class="p-5 sm:p-6">
    <div class="flex items-start gap-4">
      {logoUrl ? (
        <img
          src={logoUrl}
          alt={`${name} logo`}
          class="w-14 h-14 rounded-lg object-cover bg-cream-100 shrink-0"
          loading="lazy"
        />
      ) : (
        <div class="w-14 h-14 rounded-lg bg-cream-200 flex items-center justify-center shrink-0">
          <span class="text-xl font-bold text-charcoal-400">
            {abbreviation ? abbreviation.charAt(0) : name.charAt(0)}
          </span>
        </div>
      )}

      <div class="min-w-0 flex-1">
        <h3 class="font-semibold text-charcoal-800 group-hover:text-saffron-600 transition-colors leading-tight">
          {abbreviation && (
            <span class="text-charcoal-400 font-normal text-sm">{abbreviation} &mdash; </span>
          )}
          {name}
        </h3>

        <div class="flex flex-wrap items-center gap-2 mt-2">
          {tradition && (
            <span class:list={["text-xs font-medium px-2 py-0.5 rounded-full border", traditionColors[tradition]]}>
              {tradition.charAt(0).toUpperCase() + tradition.slice(1)}
            </span>
          )}
          {role === "founding-member" && (
            <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-dharma-50 text-dharma-600 border border-dharma-200">
              Founding Member
            </span>
          )}
        </div>
      </div>
    </div>

    {description && (
      <p class="text-sm text-charcoal-500 mt-3 leading-relaxed line-clamp-2">{description}</p>
    )}
  </div>
</a>
