---
interface Props {
  name: string;
  abbreviation?: string;
  description?: string;
  logo?: string;
  slug: string;
}

const { name, abbreviation, description, logo, slug } = Astro.props;
---

<a
  href={`/member-organisations/${slug}`}
  class="group block bg-white rounded-2xl border border-cream-200 hover:border-saffron-300 hover:shadow-xl transition-all duration-300 overflow-hidden"
>
  <div class="p-5 sm:p-6">
    <div class="flex items-center gap-4 mb-4">
      {logo ? (
        <div class="w-14 h-14 rounded-xl bg-cream-50 border border-cream-100 flex items-center justify-center shrink-0 p-1.5">
          <img
            src={logo}
            alt={`${name} logo`}
            class="w-full h-full object-contain"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="w-14 h-14 rounded-xl bg-saffron-50 border border-saffron-100 flex items-center justify-center shrink-0">
          <span class="text-xl font-bold text-saffron-400">
            {abbreviation ? abbreviation.charAt(0) : name.charAt(0)}
          </span>
        </div>
      )}
      <div class="min-w-0 flex-1">
        <h3 class="font-semibold text-charcoal-800 group-hover:text-saffron-600 transition-colors leading-tight">
          {name}
        </h3>
        {abbreviation && (
          <p class="text-xs text-charcoal-400 mt-0.5">{abbreviation}</p>
        )}
      </div>
    </div>

    {description && (
      <p class="text-sm text-charcoal-500 leading-relaxed line-clamp-2">{description}</p>
    )}

    <div class="mt-4 flex items-center gap-1 text-xs font-medium text-saffron-600 group-hover:text-saffron-700 transition-colors">
      Learn more
      <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
      </svg>
    </div>
  </div>
</a>
