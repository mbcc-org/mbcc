---
interface Props {
  name: string;
  abbreviation?: string;
  description?: string;
  logo?: string;
  slug: string;
}

const { name, abbreviation, description, logo, slug } = Astro.props;
---

<a
  href={`/organisations/${slug}`}
  class="group block bg-white rounded-xl border border-cream-200 hover:border-cream-300 hover:shadow-lg transition-all duration-200 overflow-hidden"
>
  <div class="p-5 sm:p-6">
    <div class="flex items-start gap-4">
      {logo ? (
        <img
          src={logo}
          alt={`${name} logo`}
          class="w-14 h-14 rounded-lg object-cover bg-cream-100 shrink-0"
          loading="lazy"
        />
      ) : (
        <div class="w-14 h-14 rounded-lg bg-cream-200 flex items-center justify-center shrink-0">
          <span class="text-xl font-bold text-charcoal-400">
            {abbreviation ? abbreviation.charAt(0) : name.charAt(0)}
          </span>
        </div>
      )}

      <div class="min-w-0 flex-1">
        <h3 class="font-semibold text-charcoal-800 group-hover:text-saffron-600 transition-colors leading-tight">
          {name}
          {abbreviation && (
            <span class="text-charcoal-400 font-normal text-sm"> ({abbreviation})</span>
          )}
        </h3>
      </div>
    </div>

    {description && (
      <p class="text-sm text-charcoal-500 mt-3 leading-relaxed line-clamp-2">{description}</p>
    )}

    <p class="text-sm font-medium text-saffron-600 mt-3 text-right group-hover:text-saffron-700 transition-colors">
      Read more <span class="inline-block group-hover:translate-x-0.5 transition-transform">&rarr;</span>
    </p>
  </div>
</a>
