---
import { getImageUrl } from "../lib/image";

interface Props {
  name: string;
  title: string;
  photo?: string;
}

const { name, title, photo } = Astro.props;

const photoUrl = photo ? getImageUrl(photo, { width: 200, height: 200 }) : "";
const initials = name
  .split(" ")
  .map((n) => n.charAt(0))
  .slice(0, 2)
  .join("")
  .toUpperCase();
---

<div class="flex items-center gap-4 bg-white border border-cream-200 rounded-xl p-4 hover:border-cream-300 hover:shadow-sm transition-all duration-200">
  {photoUrl ? (
    <img
      src={photoUrl}
      alt={name}
      class="w-12 h-12 rounded-full object-cover shrink-0"
      loading="lazy"
    />
  ) : (
    <div class="w-12 h-12 rounded-full bg-saffron-100 flex items-center justify-center shrink-0">
      <span class="text-sm font-bold text-saffron-600">{initials}</span>
    </div>
  )}
  <div class="min-w-0">
    <p class="text-xs font-semibold text-saffron-600 uppercase tracking-wide">{title}</p>
    <h3 class="text-sm font-semibold text-charcoal-800 leading-tight mt-0.5">{name}</h3>
  </div>
</div>
