---
import { getImageUrl } from "../lib/image";

interface Props {
  name: string;
  title: string;
  organisation?: string;
  photo?: string;
}

const { name, title, organisation, photo } = Astro.props;

const photoUrl = photo ? getImageUrl(photo, { width: 200, height: 200 }) : "";
const initials = name
  .split(" ")
  .map((n) => n.charAt(0))
  .slice(0, 2)
  .join("")
  .toUpperCase();
---

<div class="flex flex-col items-center text-center p-4">
  {photoUrl ? (
    <img
      src={photoUrl}
      alt={name}
      class="w-24 h-24 rounded-full object-cover bg-cream-200 ring-2 ring-cream-200 ring-offset-2 ring-offset-cream-50"
      loading="lazy"
    />
  ) : (
    <div class="w-24 h-24 rounded-full bg-gradient-to-br from-dharma-100 to-dharma-200 flex items-center justify-center ring-2 ring-cream-200 ring-offset-2 ring-offset-cream-50">
      <span class="text-2xl font-bold text-dharma-500">{initials}</span>
    </div>
  )}

  <h3 class="font-semibold text-charcoal-800 mt-4 leading-tight">{name}</h3>
  <p class="text-sm text-saffron-600 mt-1">{title}</p>
  {organisation && (
    <p class="text-xs text-charcoal-400 mt-0.5">{organisation}</p>
  )}
</div>
