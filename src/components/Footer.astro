---
const navLinks = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Organisations", href: "/organisations" },
  { label: "Events", href: "/events" },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-charcoal-800 text-cream-200">

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <!-- Branding + contact -->
      <div class="max-w-sm">
        <div class="mb-4">
          <img src="/logos/mbcc.png" alt="MBCC" class="h-8 w-auto" />
        </div>
        <p class="text-cream-300 text-sm leading-relaxed mb-3">
          Malaysian Buddhist Consultative Council
        </p>
        <p class="text-cream-400 text-xs leading-relaxed">
          Promoting collective effort and cooperation amongst registered Buddhist organizations in Malaysia since 1999.
        </p>
        <p class="text-cream-400 text-xs leading-relaxed mt-1">
          Registration No: PPM-023-10-29042015
        </p>
      </div>

      <!-- Navigation -->
      <div class="flex flex-col gap-5">
        <nav aria-label="Footer navigation">
          <ul class="flex flex-wrap gap-x-6 gap-y-2">
            {navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-cream-300 hover:text-saffron-400 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <a
          href="https://www.facebook.com/mybuddhistcc/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-cream-400 hover:text-saffron-400 transition-colors"
          aria-label="MBCC on Facebook"
        >
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          Facebook
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-charcoal-600 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div class="flex flex-col gap-1">
        <p class="text-xs text-charcoal-400">
          &copy; {currentYear} Malaysian Buddhist Consultative Council. All rights reserved.
        </p>
        <p class="text-xs text-charcoal-500">
          Registered under the Registrar of Society, Malaysia
        </p>
      </div>
      <a
        href="https://triwind.com.my"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 p-2 rounded-lg border border-charcoal-600 text-charcoal-400 hover:text-cream-300 hover:border-charcoal-500 transition-colors self-start shrink-0"
        aria-label="Developed by Triwind"
      >
        <span class="flex items-center justify-center w-8 h-8 rounded-md bg-white shrink-0">
          <img src="/logos/triwind.png" alt="" class="h-6 w-6 object-contain" aria-hidden="true" />
        </span>
        <span class="flex flex-col leading-tight">
          <span class="text-xs text-charcoal-500">Developed by</span>
          <span class="text-xs font-semibold text-charcoal-300">Triwind</span>
        </span>
      </a>
    </div>
  </div>
  <div class="flag-strip h-1.5 w-full" aria-hidden="true"></div>
</footer>
