---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import OrgCard from "../../components/OrgCard.astro";

const allOrgs = await getCollection("organisations");
const nationalOrgs = allOrgs.filter((org) => org.data.role !== "founding-member");
const foundingMember = allOrgs.find((org) => org.data.role === "founding-member");

const siteUrl = import.meta.env.SITE_URL || "https://mbcc.my";

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Organisations", item: `${siteUrl}/organisations` },
  ],
};
---

<BaseLayout
  title="Member Organisations — MBCC"
  description="The seven national Buddhist organisations that make up the Malaysian Buddhist Consultative Council, representing Mahayana, Theravada, and Vajrayana traditions."
  jsonLd={breadcrumbLd}
>
  <!-- Page Header -->
  <section class="bg-cream-100 border-b border-cream-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <p class="text-saffron-600 text-sm font-medium tracking-[0.15em] uppercase mb-3">Our Members</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-charcoal-800">
        Member Organisations
      </h1>
      <p class="mt-4 text-lg text-charcoal-500 max-w-2xl leading-relaxed">
        Seven national Buddhist organisations united under MBCC, representing the three major Buddhist traditions in Malaysia.
      </p>
    </div>
  </section>

  <section class="py-14 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        {foundingMember && (
          <OrgCard
            name={foundingMember.data.name}
            abbreviation={foundingMember.data.abbreviation}
            description={foundingMember.data.description}
            logo={foundingMember.data.logo}
            slug={foundingMember.id}
            role={foundingMember.data.role}
          />
        )}
        {nationalOrgs.map((org, i) => (
          <div class:list={[i === nationalOrgs.length - 1 && "sm:col-start-1 lg:col-start-2"]}>
            <OrgCard
              name={org.data.name}
              abbreviation={org.data.abbreviation}
              description={org.data.description}
              logo={org.data.logo}
              slug={org.id}
              role={org.data.role}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
