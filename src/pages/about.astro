---
import BaseLayout from "../layouts/BaseLayout.astro";
import CommitteeMember from "../components/CommitteeMember.astro";
import StatCounter from "../components/StatCounter.astro";

const siteUrl = import.meta.env.SITE_URL || "https://mbcc.org.my";

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "About", item: `${siteUrl}/about` },
  ],
};

const timelineEvents = [
  {
    year: "1999",
    title: "Formation Commences",
    description:
      "YB Dato Ong Ka Ting and Buddhist community leaders identify the need for a united Buddhist voice to liaise with the government. Initial discussions begin among key Buddhist organisations.",
  },
  {
    year: "2000–2005",
    title: "Building Consensus",
    description:
      "Under the guidance of Dato Fu Ah Kiow, the late Venerable Seck Chek Huang, and the late Venerable Dr. K. Sri Dhammananda Nāyaka Mahā Thero, national Buddhist organisations come together to discuss the formation of a consultative council.",
  },
  {
    year: "2006–2014",
    title: "Strengthening Foundations",
    description:
      "MBCC operates as an informal consultative body, building relationships between member organisations and establishing working protocols for government coordination.",
  },
  {
    year: "2015",
    title: "Official Registration",
    description:
      "MBCC is officially registered under the Registrar of Society on 29 April 2015, formalising its role as the representative body for the Malaysian Buddhist community.",
  },
];

const committee = [
  { name: "Chang Chooi Kwan", title: "President" },
  { name: "Ng Hui Chen", title: "Deputy President" },
  { name: "Loh Pai Ling", title: "Vice President" },
  { name: "Chew Eng Ghee", title: "Vice President" },
  { name: "Wong Tin Song", title: "Secretary" },
  { name: "A. Hemadasa", title: "Treasurer" },
  { name: "Liau Kok Meng", title: "Committee Member" },
  { name: "Tee Chee Seng", title: "Committee Member" },
  { name: "Chew Min Chuan", title: "Committee Member" },
  { name: "Jaclyn Tai Kai Ling", title: "Committee Member" },
  { name: "Pang Hock Huat, Jeffrey", title: "Committee Member" },
  { name: "Cheow Chin Hua", title: "Committee Member" },
  { name: "Tang Hwa Khim", title: "Committee Member" },
  { name: "Tee Siew Seet", title: "Committee Member" },
  { name: "Tilak Leslie Jayawardena", title: "Committee Member" },
  { name: "Patric Permatilaka KD Serisena", title: "Committee Member" },
  { name: "Tan Leng Huat", title: "Committee Member" },
  { name: "Khong Fong Jia", title: "Committee Member" },
  { name: "Chim Siew Choon", title: "Internal Audit" },
  { name: "Koo Yew Fook", title: "Internal Audit" },
];
---

<BaseLayout
  title="About MBCC — Mission, Governance & History"
  description="The Malaysian Buddhist Consultative Council is the national umbrella body uniting six major Buddhist organisations in Malaysia, representing the collective voice of Malaysian Buddhists."
  jsonLd={breadcrumbLd}
>
  <!-- 1. Hero Section (mission-focused) -->
  <section class="relative overflow-hidden bg-charcoal-800">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 100% at 50% 120%, rgba(232,163,23,0.12) 0%, transparent 65%);"></div>
      <!-- Decorative dharma wheel -->
      <svg class="absolute right-[-5%] top-1/2 -translate-y-1/2 w-[320px] h-[320px] text-white/[0.03]" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="0.3"/>
        <circle cx="16" cy="16" r="3" fill="currentColor"/>
        <g stroke="currentColor" stroke-width="0.3">
          <line x1="16" y1="2" x2="16" y2="30"/>
          <line x1="2" y1="16" x2="30" y2="16"/>
          <line x1="5.1" y1="5.1" x2="26.9" y2="26.9"/>
          <line x1="26.9" y1="5.1" x2="5.1" y2="26.9"/>
        </g>
      </svg>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20">
      <p class="text-saffron-400 text-xs font-semibold tracking-[0.2em] uppercase mb-3">About MBCC</p>
      <h1 class="text-4xl sm:text-5xl font-semibold text-white leading-tight max-w-2xl">
        Uniting Malaysia's Buddhist Community
      </h1>
      <p class="mt-4 text-base text-charcoal-300 max-w-xl leading-relaxed">
        The national umbrella body fostering collaboration among diverse Buddhist traditions and representing the collective voice of Malaysian Buddhists.
      </p>
    </div>
  </section>

  <!-- 2. The MBCC Story -->
  <section class="py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h2 class="text-2xl sm:text-3xl font-bold text-charcoal-800 mb-6">The MBCC Story</h2>
        <div class="space-y-4 text-charcoal-600 leading-relaxed">
          <p>
            In 1999, YB Dato Ong Ka Ting recognised the need for a unified Buddhist voice in government dialogue and convened leaders from Malaysia's major Buddhist organisations. Championed by Dato Fu Ah Kiow, the late Venerable Seck Chek Huang, and the late Venerable Dr. K. Sri Dhammananda, they laid the groundwork for MBCC over the following years.
          </p>
          <p>
            After a decade as an informal consultative body — building trust across Mahayana, Theravada, and Vajrayana traditions — MBCC was officially registered under the Registrar of Society on 29 April 2015. Today it unites six national Buddhist organisations, representing over 600 temples, ~600,000 registered members, and 5.4 million Buddhists across Malaysia.
          </p>
        </div>
      </div>

      <!-- Three subsections below the story -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-px mt-12 bg-cream-200 rounded-2xl overflow-hidden border border-cream-200">
        <div class="bg-white p-8 flex flex-col gap-3">
          <div class="w-9 h-9 rounded-lg bg-saffron-100 flex items-center justify-center shrink-0">
            <svg class="w-4.5 h-4.5 text-saffron-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-charcoal-800">Role & Purpose</h3>
          <p class="text-sm text-charcoal-500 leading-relaxed">
            The national umbrella body uniting six major Buddhist organisations, coordinating nationwide initiatives in Dharma propagation, education, welfare, and youth development.
          </p>
        </div>
        <div class="bg-white p-8 flex flex-col gap-3">
          <div class="w-9 h-9 rounded-lg bg-saffron-100 flex items-center justify-center shrink-0">
            <svg class="w-4.5 h-4.5 text-saffron-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-charcoal-800">Executive Committee &amp; Governance</h3>
          <p class="text-sm text-charcoal-500 leading-relaxed">
            The Exco, comprising representatives from member organisations, engages with Federal and State governments and international counterparts on behalf of the Buddhist community.
          </p>
        </div>
        <div class="bg-white p-8 flex flex-col gap-3">
          <div class="w-9 h-9 rounded-lg bg-saffron-100 flex items-center justify-center shrink-0">
            <svg class="w-4.5 h-4.5 text-saffron-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
            </svg>
          </div>
          <h3 class="font-semibold text-charcoal-800">Interfaith &amp; Values</h3>
          <p class="text-sm text-charcoal-500 leading-relaxed">
            Working with government agencies, interfaith bodies, and civil society to uphold Buddhist values and promote dialogue, mutual respect, and Malaysia's vision of unity.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Key Milestones -->
  <section class="bg-cream-100 border-y border-cream-200 py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-charcoal-800 mb-10">Key Milestones</h2>

      <!-- Mobile: vertical timeline -->
      <div class="sm:hidden max-w-lg space-y-0">
        {timelineEvents.map((event, i) => (
          <div class="relative pl-8 pb-8 last:pb-0">
            {i < timelineEvents.length - 1 && (
              <div class="absolute left-[11px] top-5 bottom-0 w-px bg-cream-300" aria-hidden="true"></div>
            )}
            <div class="absolute left-0.5 top-0 w-5 h-5 text-saffron-500" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" class="w-full h-full">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="12" r="2" fill="currentColor"/>
                <g stroke="currentColor" stroke-width="1" stroke-linecap="round">
                  <line x1="12" y1="2" x2="12" y2="22"/>
                  <line x1="2" y1="12" x2="22" y2="12"/>
                  <line x1="4.9" y1="4.9" x2="19.1" y2="19.1"/>
                  <line x1="19.1" y1="4.9" x2="4.9" y2="19.1"/>
                </g>
              </svg>
            </div>
            <p class="text-xs font-bold text-saffron-600 tracking-wide uppercase">{event.year}</p>
            <h3 class="text-sm font-semibold text-charcoal-800 mt-1">{event.title}</h3>
            <p class="text-sm text-charcoal-500 mt-1 leading-relaxed">{event.description}</p>
          </div>
        ))}
      </div>

      <!-- Desktop: horizontal timeline -->
      <div class="hidden sm:flex">
        {timelineEvents.map((event, i) => (
          <div class="flex-1 flex flex-col">
            <!-- Marker + connecting line -->
            <div class="flex items-center mb-4">
              <div class="w-5 h-5 shrink-0 text-saffron-500" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" class="w-full h-full">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" fill="var(--color-cream-100)"/>
                  <circle cx="12" cy="12" r="2" fill="currentColor"/>
                  <g stroke="currentColor" stroke-width="1" stroke-linecap="round">
                    <line x1="12" y1="2" x2="12" y2="22"/>
                    <line x1="2" y1="12" x2="22" y2="12"/>
                    <line x1="4.9" y1="4.9" x2="19.1" y2="19.1"/>
                    <line x1="19.1" y1="4.9" x2="4.9" y2="19.1"/>
                  </g>
                </svg>
              </div>
              {i < timelineEvents.length - 1 && (
                <div class="flex-1 h-px bg-cream-300" aria-hidden="true"></div>
              )}
            </div>
            <!-- Content -->
            <div class="pr-8">
              <p class="text-xs font-bold text-saffron-600 tracking-wide uppercase">{event.year}</p>
              <h3 class="text-sm font-semibold text-charcoal-800 mt-1">{event.title}</h3>
              <p class="text-sm text-charcoal-500 mt-1 leading-relaxed">{event.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. Statistics -->
  <section class="relative overflow-hidden bg-charcoal-800 py-14 sm:py-16">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 100% at 50% 120%, rgba(232,163,23,0.12) 0%, transparent 70%);"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-sm font-bold tracking-[0.2em] uppercase text-charcoal-400 text-center mb-10">The Buddhist Community in Malaysia</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-white/10">
        <div class="flex flex-col items-center text-center py-8 px-8 gap-2">
          <p class="text-5xl font-bold text-white leading-none tracking-tight">600+</p>
          <p class="text-sm font-medium text-saffron-400 mt-1">Buddhist Organisations</p>
          <p class="text-xs text-charcoal-400">Across all Malaysian states</p>
        </div>
        <div class="flex flex-col items-center text-center py-8 px-8 gap-2">
          <p class="text-5xl font-bold text-white leading-none tracking-tight">600K</p>
          <p class="text-sm font-medium text-saffron-400 mt-1">Registered Members</p>
          <p class="text-xs text-charcoal-400">Across 6 member organisations</p>
        </div>
        <div class="flex flex-col items-center text-center py-8 px-8 gap-2">
          <p class="text-5xl font-bold text-white leading-none tracking-tight">5.4M</p>
          <p class="text-sm font-medium text-saffron-400 mt-1">Buddhists in Malaysia</p>
          <p class="text-xs text-charcoal-400">16% of the population</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. Committee Member Cards -->
  <section class="py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <svg class="w-16 h-10 mx-auto mb-4 text-saffron-400/50" viewBox="0 0 40 24" fill="currentColor" aria-hidden="true">
          <ellipse cx="20" cy="11" rx="3.5" ry="9" opacity="0.55"/>
          <ellipse cx="20" cy="11" rx="3.2" ry="8" transform="rotate(-28 20 18)" opacity="0.4"/>
          <ellipse cx="20" cy="11" rx="3.2" ry="8" transform="rotate(28 20 18)" opacity="0.4"/>
          <ellipse cx="20" cy="11" rx="2.8" ry="7" transform="rotate(-52 20 18)" opacity="0.25"/>
          <ellipse cx="20" cy="11" rx="2.8" ry="7" transform="rotate(52 20 18)" opacity="0.25"/>
        </svg>
        <h2 class="text-2xl sm:text-3xl font-bold text-charcoal-800">Current Committee</h2>
        <p class="mt-3 text-charcoal-500">
          Office bearers guiding MBCC's mission and activities.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {committee.map((member) => (
          <CommitteeMember
            name={member.name}
            title={member.title}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 9. Contact Section -->
  <section class="relative overflow-hidden bg-charcoal-800 py-16 sm:py-20">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 80% at 50% 100%, rgba(232,163,23,0.1) 0%, transparent 70%);"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-xl mx-auto text-center">
        <p class="text-xs font-bold tracking-[0.2em] uppercase text-charcoal-400 mb-4">Get In Touch</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-2">Wong Tin Song</h2>
        <p class="text-sm text-saffron-400 font-medium mb-8">Secretary, MBCC</p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href="mailto:mbcchq@gmail.com"
            class="inline-flex items-center gap-2.5 px-5 py-3 rounded-lg bg-white/10 hover:bg-white/15 border border-white/10 hover:border-white/20 text-white text-sm transition-all duration-150 w-full sm:w-auto justify-center"
          >
            <svg class="w-4 h-4 text-saffron-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
            mbcchq@gmail.com
          </a>
          <a
            href="tel:+601161700123"
            class="inline-flex items-center gap-2.5 px-5 py-3 rounded-lg bg-white/10 hover:bg-white/15 border border-white/10 hover:border-white/20 text-white text-sm transition-all duration-150 w-full sm:w-auto justify-center"
          >
            <svg class="w-4 h-4 text-saffron-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            +601161700123
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
