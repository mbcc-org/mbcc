---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PhotoGallery from "../../components/PhotoGallery.astro";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const siteUrl = import.meta.env.SITE_URL || "https://mbcc.my";

const formattedDate = event.data.date.toLocaleDateString("en-MY", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedEndDate = event.data.endDate?.toLocaleDateString("en-MY", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
});

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Events", item: `${siteUrl}/events` },
    { "@type": "ListItem", position: 3, name: event.data.title, item: `${siteUrl}/events/${event.id}` },
  ],
};

const eventLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: event.data.title,
  startDate: event.data.date.toISOString(),
  ...(event.data.endDate && { endDate: event.data.endDate.toISOString() }),
  ...(event.data.location && {
    location: {
      "@type": "Place",
      name: event.data.location,
    },
  }),
  ...(event.data.description && { description: event.data.description }),
  organizer: {
    "@type": "Organization",
    name: "Malaysian Buddhist Consultative Council",
    url: siteUrl,
  },
};
---

<BaseLayout
  title={`${event.data.title} — MBCC Events`}
  description={event.data.description || event.data.title}
  jsonLd={[breadcrumbLd, eventLd]}
>
  <!-- Page Header -->
  <section class="bg-cream-100 border-b border-cream-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <!-- Breadcrumb -->
      <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-charcoal-400">
          <li><a href="/events" class="hover:text-dharma-500 transition-colors">Events</a></li>
          <li aria-hidden="true">/</li>
          <li class="text-charcoal-600 truncate max-w-[200px]">{event.data.title}</li>
        </ol>
      </nav>

      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-charcoal-800 leading-tight">
        {event.data.title}
      </h1>

      <div class="flex flex-wrap items-center gap-4 mt-4 text-sm text-charcoal-500">
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-saffron-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
          </svg>
          <time datetime={event.data.date.toISOString().split("T")[0]}>
            {formattedDate}
            {formattedEndDate && ` — ${formattedEndDate}`}
          </time>
        </div>

        {event.data.location && (
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-saffron-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
            <span>{event.data.location}</span>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="py-12 sm:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Content -->
      <div class="prose max-w-none">
        <Content />
      </div>

      <script>
        import GLightbox from "glightbox";
        import "glightbox/dist/css/glightbox.min.css";

        const initLightbox = () =>
          GLightbox({
            selector: ".glightbox",
            touchNavigation: true,
            loop: false,
            closeOnOutsideClick: true,
          });

        document.addEventListener("astro:page-load", initLightbox);
        initLightbox();
      </script>

      {/* Photo Gallery */}
      {event.data.photos && event.data.photos.length > 0 && (
        <div class="mt-14">
          <h2 class="text-xl font-bold text-charcoal-800 mb-6">Event Photos</h2>
          <PhotoGallery photos={event.data.photos} />
        </div>
      )}

      <!-- Back link -->
      <div class="mt-14 pt-8 border-t border-cream-200">
        <a
          href="/events"
          class="inline-flex items-center text-sm text-charcoal-400 hover:text-dharma-500 transition-colors"
        >
          <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 15.75L3 12m0 0l3.75-3.75M3 12h18" />
          </svg>
          All events
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
