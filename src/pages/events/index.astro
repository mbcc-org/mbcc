---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EventCard from "../../components/EventCard.astro";

const allEvents = await getCollection("events");
const sortedEvents = allEvents.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const siteUrl = import.meta.env.SITE_URL || "https://mbcc.org.my";

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Events", item: `${siteUrl}/events` },
  ],
};
---

<BaseLayout
  title="Events — MBCC"
  description="Buddhist community events, celebrations, and conferences organised by MBCC and its member organisations."
  jsonLd={breadcrumbLd}
>
  <!-- Page Header -->
  <section class="relative overflow-hidden bg-charcoal-800">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 120% at 0% 50%, rgba(232,163,23,0.1) 0%, transparent 60%);"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20">
      <p class="text-saffron-400 text-xs font-semibold tracking-[0.2em] uppercase mb-3">Community</p>
      <h1 class="text-4xl sm:text-5xl font-semibold text-white leading-tight">Events</h1>
      <p class="mt-4 text-base text-charcoal-300 max-w-xl leading-relaxed">
        Celebrations, conferences, and community activities from MBCC and our member organisations.
      </p>
    </div>
  </section>

  <section class="py-14 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {sortedEvents.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {sortedEvents.map((event) => (
            <EventCard
              title={event.data.title}
              date={event.data.date}
              description={event.data.description}
              slug={event.id}
              thumbnail={event.data.thumbnail || event.data.photos?.[0]?.path}
              location={event.data.location}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <svg class="w-16 h-16 mx-auto text-cream-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
          </svg>
          <p class="text-charcoal-400">No events posted yet. Check back soon.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
