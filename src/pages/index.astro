---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import OrgCard from "../components/OrgCard.astro";
import StatCounter from "../components/StatCounter.astro";
import EventCard from "../components/EventCard.astro";
import jataNegaraUrl from "../assets/svg/jata-negara.svg?url";

const allOrgs = await getCollection("organisations");

const allEvents = await getCollection("events");
const recentEvents = allEvents
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const siteUrl = import.meta.env.SITE_URL || "https://mbcc.org.my";

const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Malaysian Buddhist Consultative Council",
  alternateName: "MBCC",
  description:
    "A non-profit interfaith organisation that promotes collective effort and cooperation amongst registered Buddhist organisations in Malaysia.",
  url: siteUrl,
  logo: `${siteUrl}/logos/mbcc.png`,
  foundingDate: "2015-04-29",
  taxID: "PPM-023-10-29042015",
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "administrative",
    email: "mbcchq@gmail.com",
    telephone: "+601161700123",
    name: "Wong Tin Song",
  },
  member: allOrgs.map((org) => ({
    "@type": "Organization",
    name: org.data.name,
    ...(org.data.website && { url: org.data.website }),
  })),
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "MBCC",
  url: siteUrl,
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl,
    },
  ],
};
---

<BaseLayout
  title="MBCC — Malaysian Buddhist Consultative Council"
  description="Promoting collective effort and cooperation amongst Buddhist organisations in Malaysia. Representing 600 organisations and 5.4 million Buddhists."
  jsonLd={[organizationLd, websiteLd, breadcrumbLd]}
>
  <!-- Wesak 2026 Banner -->
  <div class="wesak-banner relative overflow-hidden text-center" style="background: #92400e;">
    <!-- Background image with fade-in -->
    <img
      src="/images/malaysia-buddhist.png"
      alt=""
      class="wesak-bg-img absolute inset-0 w-full h-full object-cover"
      aria-hidden="true"
      loading="eager"
    />

    <!-- Gold overlay to blend image with saffron palette -->
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(135deg, rgba(146,64,14,0.88) 0%, rgba(217,119,6,0.82) 40%, rgba(245,158,11,0.78) 60%, rgba(146,64,14,0.88) 100%);"></div>

    <!-- Shimmer sweep -->
    <div class="wesak-shimmer absolute inset-0 pointer-events-none" aria-hidden="true"></div>

    <!-- Bottom vignette for text legibility -->
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to bottom, rgba(60,20,0,0.25) 0%, transparent 40%, transparent 60%, rgba(60,20,0,0.35) 100%);" aria-hidden="true"></div>

    <!-- Side rings -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -left-24 top-1/2 -translate-y-1/2 w-96 h-96 rounded-full border border-white/[0.07]"></div>
      <div class="absolute -left-12 top-1/2 -translate-y-1/2 w-56 h-56 rounded-full border border-white/[0.07]"></div>
      <div class="absolute -right-24 top-1/2 -translate-y-1/2 w-96 h-96 rounded-full border border-white/[0.07]"></div>
      <div class="absolute -right-12 top-1/2 -translate-y-1/2 w-56 h-56 rounded-full border border-white/[0.07]"></div>
    </div>

    <div class="relative py-10 sm:py-12 px-4">
      <!-- Eyebrow -->
      <p class="text-[10px] sm:text-xs font-bold tracking-[0.35em] uppercase mb-3 sm:mb-4 text-white/55">Upcoming Events</p>

      <!-- Co-host logos -->
      <div class="flex items-center justify-center gap-5 mb-4 sm:mb-5">
        <div class="flex items-center justify-center rounded-full bg-white w-14 h-14 sm:w-16 sm:h-16 shrink-0" style="box-shadow: 0 1px 4px rgba(0,0,0,0.4);">
          <img
            src={jataNegaraUrl}
            alt="Jata Negara — Government of Malaysia"
            class="w-10 h-10 sm:w-12 sm:h-12 object-contain"
          />
        </div>
        <div class="flex items-center justify-center rounded-full bg-white w-14 h-14 sm:w-16 sm:h-16 shrink-0" style="box-shadow: 0 1px 4px rgba(0,0,0,0.4);">
          <img
            src="/logos/mbcc.png"
            alt="MBCC"
            class="w-12 h-12 sm:w-14 sm:h-14 object-contain"
            style="transform: translateY(-3px);"
          />
        </div>
      </div>

      <!-- Title -->
      <div class="mb-5 sm:mb-7">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-none" style="font-family: 'Cormorant', Georgia, serif; letter-spacing: -0.01em; text-shadow: 0 2px 20px rgba(80,30,0,0.5);">
          National Wesak 2026
        </h2>
        <p class="mt-2 text-[10px] sm:text-xs font-semibold tracking-[0.25em] uppercase text-white/70">Celebrating Together Across Malaysia</p>
      </div>

      <!-- Event pills -->
      <div class="flex items-center justify-center gap-3 flex-wrap">
        <a href="/events/national-wesak-conference-2026" class="inline-flex flex-col sm:flex-row items-center gap-0.5 sm:gap-3 px-5 sm:px-6 py-2 sm:py-2.5 rounded-full hover:scale-105 transition-all duration-150" style="background: rgba(22,10,2,0.72); backdrop-filter: blur(6px); box-shadow: 0 2px 12px rgba(0,0,0,0.25);">
          <span class="text-xs sm:text-sm font-semibold text-white">Conference</span>
          <span class="text-[10px] sm:text-xs font-bold text-amber-300" style="letter-spacing:0.03em;">23 May</span>
        </a>
        <span class="text-white/20 text-sm select-none" aria-hidden="true">◇</span>
        <a href="/events/nationwide-grassroots-wesak-celebrations-2026" class="inline-flex flex-col sm:flex-row items-center gap-0.5 sm:gap-3 px-5 sm:px-6 py-2 sm:py-2.5 rounded-full hover:scale-105 transition-all duration-150" style="background: rgba(22,10,2,0.72); backdrop-filter: blur(6px); box-shadow: 0 2px 12px rgba(0,0,0,0.25);">
          <span class="text-xs sm:text-sm font-semibold text-white">Celebrations</span>
          <span class="text-[10px] sm:text-xs font-bold text-amber-300" style="letter-spacing:0.03em;">31 May</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-charcoal-800">
    <!-- Muted background photo -->
    <div class="absolute inset-0">
      <img
        src="https://picsum.photos/seed/mbcc-hero/1920/800"
        alt=""
        class="w-full h-full object-cover opacity-30"
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-charcoal-800/60 via-charcoal-800/40 to-charcoal-800/80"></div>
    </div>

    <!-- Decorative dharma wheel watermark -->
    <svg
      class="absolute right-[-8%] top-1/2 -translate-y-1/2 w-[500px] h-[500px] text-cream-100/[0.03]"
      viewBox="0 0 32 32"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="0.3" />
      <circle cx="16" cy="16" r="3" fill="currentColor" />
      <g stroke="currentColor" stroke-width="0.3">
        <line x1="16" y1="2" x2="16" y2="30" />
        <line x1="2" y1="16" x2="30" y2="16" />
        <line x1="5.1" y1="5.1" x2="26.9" y2="26.9" />
        <line x1="26.9" y1="5.1" x2="5.1" y2="26.9" />
      </g>
    </svg>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
      <div class="max-w-2xl">
        <p class="text-saffron-300 text-sm font-medium tracking-[0.2em] uppercase mb-4">
          Malaysian Buddhist Consultative Council
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-cream-50 leading-tight">
          Uniting the Buddhist Community of Malaysia
        </h1>
        <p class="mt-6 text-base text-cream-200/70 leading-relaxed max-w-xl">
          Promoting collective effort and cooperation amongst Buddhist organisations to discuss common issues and coordinate with government authorities on matters of the Buddhist religion.
        </p>
        <a
          href="/about"
          class="inline-flex items-center mt-8 text-sm font-medium text-saffron-300 hover:text-saffron-200 transition-colors group"
        >
          Learn more about us
          <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Member Organisations -->
  <section class="py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <!-- Decorative lotus -->
        <svg class="w-16 h-10 mx-auto mb-4 text-saffron-400/50" viewBox="0 0 40 24" fill="currentColor" aria-hidden="true">
          <!-- Center petal -->
          <ellipse cx="20" cy="11" rx="3.5" ry="9" opacity="0.55"/>
          <!-- Inner petals -->
          <ellipse cx="20" cy="11" rx="3.2" ry="8" transform="rotate(-28 20 18)" opacity="0.4"/>
          <ellipse cx="20" cy="11" rx="3.2" ry="8" transform="rotate(28 20 18)" opacity="0.4"/>
          <!-- Outer petals -->
          <ellipse cx="20" cy="11" rx="2.8" ry="7" transform="rotate(-52 20 18)" opacity="0.25"/>
          <ellipse cx="20" cy="11" rx="2.8" ry="7" transform="rotate(52 20 18)" opacity="0.25"/>
        </svg>
        <h2 class="text-2xl sm:text-3xl font-bold text-charcoal-800">
          Member Organisations
        </h2>
        <p class="mt-3 text-charcoal-500 max-w-xl mx-auto">
          Six national Buddhist organisations united under MBCC, representing Mahayana, Theravada, and Vajrayana traditions.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        {allOrgs.map((org) => (
          <OrgCard
            name={org.data.name}
            abbreviation={org.data.abbreviation}
            description={org.data.description}
            logo={org.data.logo}
            slug={org.id}
          />
        ))}
      </div>

    </div>
  </section>

  <!-- Stats Strip -->
  <section class="relative overflow-hidden bg-charcoal-800">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 100% at 50% 120%, rgba(232,163,23,0.12) 0%, transparent 70%);"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 divide-y lg:divide-y-0 lg:divide-x divide-white/10 py-2 lg:py-0">
        <StatCounter value="600+" label="Buddhist Organisations" icon="temple" />
        <StatCounter value="600,000" label="Registered Members" icon="people" />
        <StatCounter value="5.4M" label="Buddhists in Malaysia" icon="lotus" />
      </div>
    </div>
  </section>

  <!-- Recent Events -->
  {recentEvents.length > 0 && (
    <section class="py-16 sm:py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-charcoal-800">
              Our Events
            </h2>
            <p class="mt-2 text-charcoal-500">
              Activities and celebrations from the MBCC community.
            </p>
          </div>
          <a
            href="/events"
            class="hidden sm:inline-flex items-center text-sm font-medium text-saffron-600 hover:text-saffron-700 transition-colors"
          >
            All events
            <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {recentEvents.map((event) => (
            <EventCard
              title={event.data.title}
              date={event.data.date}
              description={event.data.description}
              slug={event.id}
              thumbnail={event.data.thumbnail || event.data.photos?.[0]?.path}
              location={event.data.location}
            />
          ))}
        </div>

        <div class="sm:hidden text-center mt-6">
          <a
            href="/events"
            class="inline-flex items-center text-sm font-medium text-saffron-600 hover:text-saffron-700 transition-colors"
          >
            View all events
            <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}
<style>
  .wesak-bg-img {
    animation: wesak-fadein 1.2s ease-out both;
  }
  @keyframes wesak-fadein {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .wesak-shimmer {
    background: linear-gradient(
      108deg,
      transparent 28%,
      rgba(255, 255, 255, 0.15) 45%,
      rgba(255, 255, 255, 0.06) 50%,
      transparent 68%
    );
    animation: wesak-shimmer 6s ease-in-out infinite;
  }
  @keyframes wesak-shimmer {
    0% { transform: translateX(-150%) skewX(-12deg); }
    100% { transform: translateX(250%) skewX(-12deg); }
  }
</style>
</BaseLayout>
