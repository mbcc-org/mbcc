---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import OrgCard from "../components/OrgCard.astro";
import StatCounter from "../components/StatCounter.astro";
import EventCard from "../components/EventCard.astro";

const allOrgs = await getCollection("organisations");
const nationalOrgs = allOrgs.filter((org) => org.data.role !== "founding-member");
const foundingMember = allOrgs.find((org) => org.data.role === "founding-member");

const allEvents = await getCollection("events");
const recentEvents = allEvents
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const siteUrl = import.meta.env.SITE_URL || "https://mbcc.my";

const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Malaysian Buddhist Consultative Council",
  alternateName: "MBCC",
  description:
    "A non-profit interfaith organization that promotes collective effort and cooperation amongst registered Buddhist organizations in Malaysia.",
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  foundingDate: "2015-04-29",
  member: allOrgs.map((org) => ({
    "@type": "Organization",
    name: org.data.name,
    ...(org.data.website && { url: org.data.website }),
  })),
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "MBCC",
  url: siteUrl,
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl,
    },
  ],
};
---

<BaseLayout
  title="MBCC — Malaysian Buddhist Consultative Council"
  description="Promoting collective effort and cooperation amongst Buddhist organizations in Malaysia. Representing 600 organisations and 5.4 million Buddhists."
  jsonLd={[organizationLd, websiteLd, breadcrumbLd]}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-charcoal-800">
    <!-- Muted background photo -->
    <div class="absolute inset-0">
      <img
        src="https://picsum.photos/seed/mbcc-hero/1920/800"
        alt=""
        class="w-full h-full object-cover opacity-30"
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-charcoal-800/60 via-charcoal-800/40 to-charcoal-800/80"></div>
    </div>

    <!-- Decorative dharma wheel watermark -->
    <svg
      class="absolute right-[-8%] top-1/2 -translate-y-1/2 w-[500px] h-[500px] text-cream-100/[0.03]"
      viewBox="0 0 32 32"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="0.3" />
      <circle cx="16" cy="16" r="3" fill="currentColor" />
      <g stroke="currentColor" stroke-width="0.3">
        <line x1="16" y1="2" x2="16" y2="30" />
        <line x1="2" y1="16" x2="30" y2="16" />
        <line x1="5.1" y1="5.1" x2="26.9" y2="26.9" />
        <line x1="26.9" y1="5.1" x2="5.1" y2="26.9" />
      </g>
    </svg>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
      <div class="max-w-2xl">
        <p class="text-saffron-300 text-sm font-medium tracking-[0.2em] uppercase mb-4">
          Malaysian Buddhist Consultative Council
        </p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-cream-50 leading-tight">
          Uniting the Buddhist Community of Malaysia
        </h1>
        <p class="mt-6 text-lg text-cream-200/80 leading-relaxed max-w-xl">
          Promoting collective effort and cooperation amongst Buddhist organisations to discuss common issues and coordinate with government authorities on matters of the Buddhist religion.
        </p>
        <a
          href="/about"
          class="inline-flex items-center mt-8 text-sm font-medium text-saffron-300 hover:text-saffron-200 transition-colors group"
        >
          Learn about our history
          <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Member Organisations -->
  <section class="py-16 sm:py-20 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <!-- Decorative lotus -->
        <svg class="w-10 h-6 mx-auto mb-4 text-saffron-400/50" viewBox="0 0 120 40" fill="currentColor" aria-hidden="true">
          <path d="M60 4 C60 4, 72 14, 72 26 C72 32, 67 36, 60 36 C53 36, 48 32, 48 26 C48 14, 60 4, 60 4Z" opacity="0.5"/>
          <path d="M60 8 C60 8, 50 16, 40 24 C34 30, 38 34, 44 32 C50 30, 56 22, 60 8Z" opacity="0.35"/>
          <path d="M60 8 C60 8, 70 16, 80 24 C86 30, 82 34, 76 32 C70 30, 64 22, 60 8Z" opacity="0.35"/>
        </svg>
        <h2 class="text-2xl sm:text-3xl font-bold text-charcoal-800">
          Member Organisations
        </h2>
        <p class="mt-3 text-charcoal-500 max-w-xl mx-auto">
          Seven national Buddhist organisations united under MBCC, representing Mahayana, Theravada, and Vajrayana traditions.
        </p>
      </div>

      <!-- National org grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        {nationalOrgs.map((org) => (
          <OrgCard
            name={org.data.name}
            abbreviation={org.data.abbreviation}
            tradition={org.data.tradition}
            description={org.data.description}
            logo={org.data.logo}
            slug={org.id}
            role={org.data.role}
          />
        ))}
      </div>

      <!-- Founding member — own row below -->
      {foundingMember && (
        <div class="mt-6 max-w-lg mx-auto">
          <OrgCard
            name={foundingMember.data.name}
            abbreviation={foundingMember.data.abbreviation}
            tradition={foundingMember.data.tradition}
            description={foundingMember.data.description}
            logo={foundingMember.data.logo}
            slug={foundingMember.id}
            role={foundingMember.data.role}
          />
        </div>
      )}

      <div class="text-center mt-8">
        <a
          href="/organisations"
          class="inline-flex items-center text-sm font-medium text-dharma-500 hover:text-dharma-600 transition-colors"
        >
          View all organisations
          <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="bg-cream-100 border-y border-cream-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-12 lg:gap-16 py-8 sm:py-6">
        <StatCounter value="600+" label="Buddhist Organisations" icon="temple" />
        <div class="hidden sm:block w-px h-12 bg-cream-300" aria-hidden="true"></div>
        <StatCounter value="600,000" label="Registered Members" icon="people" />
        <div class="hidden sm:block w-px h-12 bg-cream-300" aria-hidden="true"></div>
        <StatCounter value="5.4M" label="Buddhists in Malaysia" icon="lotus" />
      </div>
    </div>
  </section>

  <!-- Recent Events -->
  {recentEvents.length > 0 && (
    <section class="py-16 sm:py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-8">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-charcoal-800">
              Recent Events
            </h2>
            <p class="mt-2 text-charcoal-500">
              Latest activities and celebrations from the MBCC community.
            </p>
          </div>
          <a
            href="/events"
            class="hidden sm:inline-flex items-center text-sm font-medium text-dharma-500 hover:text-dharma-600 transition-colors"
          >
            All events
            <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {recentEvents.map((event) => (
            <EventCard
              title={event.data.title}
              date={event.data.date}
              description={event.data.description}
              slug={event.id}
              thumbnail={event.data.photos?.[0]?.path}
              location={event.data.location}
            />
          ))}
        </div>

        <div class="sm:hidden text-center mt-6">
          <a
            href="/events"
            class="inline-flex items-center text-sm font-medium text-dharma-500 hover:text-dharma-600 transition-colors"
          >
            View all events
            <svg class="w-4 h-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
