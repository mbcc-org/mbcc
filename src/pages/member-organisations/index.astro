---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import OrgCard from "../../components/OrgCard.astro";

const allOrgs = await getCollection("organisations");

const siteUrl = import.meta.env.SITE_URL || "https://mbcc.org.my";

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Member Organisations", item: `${siteUrl}/member-organisations` },
  ],
};
---

<BaseLayout
  title="Member Organisations — MBCC"
  description="The six national Buddhist organisations that make up the Malaysian Buddhist Consultative Council, representing Mahayana, Theravada, and Vajrayana traditions."
  jsonLd={breadcrumbLd}
>
  <!-- Page Header -->
  <section class="relative overflow-hidden bg-charcoal-800">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 120% at 100% 50%, rgba(232,163,23,0.1) 0%, transparent 60%);"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20">
      <p class="text-saffron-400 text-xs font-semibold tracking-[0.2em] uppercase mb-3">Our Members</p>
      <h1 class="text-4xl sm:text-5xl font-semibold text-white leading-tight">Member Organisations</h1>
      <p class="mt-4 text-base text-charcoal-300 max-w-xl leading-relaxed">
        Six national Buddhist organisations united under MBCC, representing the three major Buddhist traditions in Malaysia.
      </p>
    </div>
  </section>

  <section class="py-14 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
        {allOrgs.map((org) => (
          <OrgCard
            name={org.data.name}
            abbreviation={org.data.abbreviation}
            description={org.data.description}
            logo={org.data.logo}
            slug={org.id}
          />
        ))}
      </div>

      <!-- CTA to Registered Organisations -->
      <div class="mt-14 pt-10 border-t border-cream-200">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 rounded-xl bg-saffron-50 border border-saffron-200 px-6 py-5">
          <div>
            <p class="text-sm font-semibold text-charcoal-700">Looking for grassroots registered organisations?</p>
            <p class="text-sm text-charcoal-500 mt-0.5">Browse Buddhist organisations across Malaysia registered with MBCC.</p>
          </div>
          <a
            href="/registered-organisations"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-saffron-600 hover:text-saffron-700 transition-colors whitespace-nowrap shrink-0"
          >
            View Registered Organisations
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
