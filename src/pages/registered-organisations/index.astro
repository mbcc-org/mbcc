---
import BaseLayout from "../../layouts/BaseLayout.astro";
import orgsData from "../../data/registered-organisations.json";

const siteUrl = import.meta.env.SITE_URL || "https://mbcc.org.my";

const states = [...new Set(orgsData.map((o) => o.state).filter(Boolean))].sort();

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Registered Organisations", item: `${siteUrl}/registered-organisations` },
  ],
};
---

<BaseLayout
  title="Registered Organisations — MBCC"
  description="Browse the full list of Buddhist organisations across Malaysia registered with MBCC for Wesak 2026 grassroots celebrations."
  jsonLd={breadcrumbLd}
>
  <!-- Page Header -->
  <section class="relative overflow-hidden bg-charcoal-800">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 120% at 0% 50%, rgba(232,163,23,0.1) 0%, transparent 60%);"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20">
      <p class="text-saffron-400 text-xs font-semibold tracking-[0.2em] uppercase mb-3">Wesak 2026</p>
      <h1 class="text-4xl sm:text-5xl font-semibold text-white leading-tight">Registered Organisations</h1>
      <p class="mt-4 text-base text-charcoal-300 max-w-xl leading-relaxed">
        Buddhist organisations across Malaysia registered with MBCC for the Wesak 2026 grassroots celebrations.
      </p>
    </div>
  </section>

  <!-- Table Section -->
  <section class="py-10 sm:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Search & Filter Controls -->
      <div class="flex flex-col sm:flex-row gap-3 mb-6">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-charcoal-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
          <input
            id="search-input"
            type="search"
            placeholder="Search organisations..."
            class="w-full pl-9 pr-4 py-2.5 text-sm border border-cream-300 rounded-lg bg-white text-charcoal-700 placeholder-charcoal-400 focus:outline-none focus:ring-2 focus:ring-saffron-400 focus:border-transparent"
            autocomplete="off"
          />
        </div>
        <select
          id="state-filter"
          class="px-4 py-2.5 text-sm border border-cream-300 rounded-lg bg-white text-charcoal-700 focus:outline-none focus:ring-2 focus:ring-saffron-400 focus:border-transparent sm:w-48"
        >
          <option value="">All States</option>
          {states.map((s) => <option value={s}>{s}</option>)}
        </select>
      </div>

      <!-- Table -->
      <div class="rounded-xl border border-cream-200 overflow-hidden">
        <table class="w-full text-sm" id="orgs-table">
          <thead>
            <tr class="bg-charcoal-800 text-left">
              <th class="px-4 py-3 text-xs font-bold uppercase tracking-[0.12em] text-cream-300 w-full">Organisation</th>
              <th class="px-4 py-3 text-xs font-bold uppercase tracking-[0.12em] text-cream-300 whitespace-nowrap hidden sm:table-cell">State</th>
              <th class="px-4 py-3 text-xs font-bold uppercase tracking-[0.12em] text-cream-300 whitespace-nowrap hidden md:table-cell">Reg. No.</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-cream-100 bg-white" id="orgs-tbody">
            {orgsData.map((org) => {
              const primaryName = org.nameEn || org.nameMs;
              return (
                <tr
                  class="hover:bg-cream-50 transition-colors org-row"
                  data-name-en={org.nameEn.toLowerCase()}
                  data-name-ms={org.nameMs.toLowerCase()}
                  data-name-zh={org.nameZh.toLowerCase()}
                  data-state={org.state.toLowerCase()}
                  data-reg={org.registrationNo.toLowerCase()}
                >
                  <td class="px-4 py-3">
                    <span class="font-medium text-charcoal-800 leading-snug block">{primaryName}</span>
                    {org.nameZh && (
                      <span class="text-xs text-charcoal-400 mt-0.5 block">{org.nameZh}</span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-charcoal-500 whitespace-nowrap hidden sm:table-cell">{org.state}</td>
                  <td class="px-4 py-3 text-charcoal-400 font-mono text-xs whitespace-nowrap hidden md:table-cell">{org.registrationNo}</td>
                </tr>
              );
            })}
          </tbody>
        </table>

        <!-- Empty state -->
        <div id="orgs-empty" class="hidden py-16 text-center text-charcoal-400">
          <svg class="w-10 h-10 mx-auto mb-3 text-charcoal-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
          <p class="text-sm">No organisations match your search.</p>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById("search-input") as HTMLInputElement;
  const stateFilter = document.getElementById("state-filter") as HTMLSelectElement;
  const rows = document.querySelectorAll<HTMLTableRowElement>(".org-row");
  const emptyState = document.getElementById("orgs-empty")!;

  function filterTable() {
    const query = searchInput.value.toLowerCase().trim();
    const state = stateFilter.value.toLowerCase();
    let visibleCount = 0;

    rows.forEach((row) => {
      const matchesSearch =
        !query ||
        row.dataset.nameEn!.includes(query) ||
        row.dataset.nameMs!.includes(query) ||
        row.dataset.nameZh!.includes(query) ||
        row.dataset.state!.includes(query) ||
        row.dataset.reg!.includes(query);

      const matchesState = !state || row.dataset.state === state;

      const visible = matchesSearch && matchesState;
      row.style.display = visible ? "" : "none";
      if (visible) visibleCount++;
    });

    emptyState.classList.toggle("hidden", visibleCount > 0);
  }

  searchInput.addEventListener("input", filterTable);
  stateFilter.addEventListener("change", filterTable);
</script>
